---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import GalleryView from '../../components/GalleryView.astro';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map(project => ({
    params: { id: project.id },
    props: { project }
  }));
}

const { project } = Astro.props;
---

<Layout title={`${project.title} - egyheppem`}>
  <Header />
  <GalleryView />
  
  <main class="main">
    <section class="section">
      <div class="container">
        <!-- Project Header -->
        <div class="project-header animate-fade-in">
          <a href="/projects" class="back-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="19" y1="12" x2="5" y2="12"></line>
              <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to projects
          </a>
          
          <h1 class="project-title">{project.title}</h1>
          <div class="project-meta">
            <span class="project-category">{project.category}</span>
            <span class="project-count">{project.imageCount} images</span>
          </div>
          <p class="project-description">{project.description}</p>
        </div>

        <!-- Main Image -->
        <div class="main-image animate-scale-in stagger-1">
          <img src={project.coverImage || "/placeholder.svg"} alt={project.title} />
        </div>

        <!-- Gallery or Subfolders -->
        {project.hasSubfolders && project.subfolders ? (
          <div class="subfolders-grid">
            <h2 class="section-subtitle animate-fade-in stagger-2">Collections</h2>
            <div class="folders-grid">
              {project.subfolders.map((subfolder, index) => (
                <a 
                  href={`/projects/${project.id}/${subfolder.id}`}
                  class={`folder-card animate-scale-in stagger-${index + 3}`}
                >
                  <img src={subfolder.coverImage || "/placeholder.svg"} alt={subfolder.title} />
                  <div class="folder-info">
                    <h3 class="folder-title">{subfolder.title}</h3>
                    <span class="folder-count">{subfolder.imageCount} images</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ) : (
          <div class="images-grid">
            <h2 class="section-subtitle animate-fade-in stagger-2">Gallery</h2>
            <div class="gallery-grid">
              {project.images.map((image, index) => (
                <div 
                  class={`gallery-item animate-scale-in stagger-${(index % 6) + 3}`}
                  data-image-url={image.url}
                  data-image-title={image.title}
                  data-image-index={index}
                >
                  <img src={image.url || "/placeholder.svg"} alt={image.title} loading="lazy" />
                  <div class="gallery-item-overlay">
                    <h3 class="gallery-item-title">{image.title}</h3>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container">
      <p>&copy; 2025 Kosiba Zsófia. All rights reserved.</p>
    </div>
  </footer>
</Layout>

<style>
  .main {
    padding-top: 80px;
    min-height: 100vh;
  }

  .section {
    padding: var(--spacing-2xl) 0;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 var(--spacing-lg);
  }

  .project-header {
    margin-bottom: var(--spacing-2xl);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    margin-bottom: var(--spacing-lg);
    transition: color var(--transition-fast), gap var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-text);
    gap: var(--spacing-sm);
  }

  .project-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 600;
    margin-bottom: var(--spacing-md);
  }

  .project-meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-md);
  }

  .project-category {
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
  }

  .project-count {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .project-description {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: 800px;
  }

  .main-image {
    margin-bottom: var(--spacing-2xl);
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .main-image img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .section-subtitle {
    font-size: 2rem;
    font-weight: 600;
    margin-bottom: var(--spacing-xl);
  }

  .folders-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: var(--spacing-lg);
  }

  .folder-card {
    display: block;
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .folder-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
  }

  .folder-card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .folder-card:hover img {
    transform: scale(1.05);
  }

  .folder-info {
    padding: var(--spacing-lg);
  }

  .folder-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: var(--spacing-xs);
  }

  .folder-count {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--spacing-lg);
  }

  .gallery-item {
    position: relative;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-lg);
    overflow: hidden;
    cursor: pointer;
    background: var(--color-surface);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .gallery-item:hover img {
    transform: scale(1.05);
  }

  .gallery-item-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.9) 0%, transparent 60%);
    display: flex;
    align-items: flex-end;
    padding: var(--spacing-lg);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .gallery-item:hover .gallery-item-overlay {
    opacity: 1;
  }

  .gallery-item-title {
    font-size: 1.125rem;
    font-weight: 600;
  }

  .footer {
    padding: var(--spacing-xl) 0;
    border-top: 1px solid var(--color-border);
    text-align: center;
    color: var(--color-text-secondary);
  }

  @media (max-width: 768px) {
    .folders-grid,
    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Gallery item click handlers
  document.addEventListener('DOMContentLoaded', () => {
    const galleryItems = document.querySelectorAll('.gallery-item');
    
    // Collect all images for gallery view
    const images = Array.from(galleryItems).map(item => ({
      url: item.getAttribute('data-image-url') || '',
      title: item.getAttribute('data-image-title') || ''
    }));

    galleryItems.forEach((item, index) => {
      item.addEventListener('click', () => {
        (window as any).openGallery(images, index);
      });
    });
  });
</script>
