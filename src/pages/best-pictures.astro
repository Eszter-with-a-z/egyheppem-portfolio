---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import GalleryView from '../components/GalleryView.astro';
import { getBestPictures } from '../data/projects';

const bestPictures = getBestPictures();
---

<Layout title="Best Pictures - egyheppem">
  <Header />
  <GalleryView />
  
  <main class="main">
    <section class="section">
      <div class="container">
        <div class="page-header animate-fade-in">
          <h1 class="page-title">Best Pictures</h1>
          <p class="page-description">A curated collection of my finest work</p>
        </div>

        <div class="gallery-grid">
          {bestPictures.map((picture, index) => (
            <div 
              class={`gallery-item animate-scale-in stagger-${(index % 6) + 1}`}
              data-image-url={picture.url}
              data-image-title={picture.title}
              data-image-index={index}
            >
              <img src={picture.url || "/placeholder.svg"} alt={picture.title} loading="lazy" />
              <div class="gallery-item-overlay">
                <h3 class="gallery-item-title">{picture.title}</h3>
                <a href={`/projects/${picture.projectId}`} class="gallery-item-link">
                  More about the project
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container">
      <p>&copy; 2025 Kosiba Zsófia. All rights reserved.</p>
    </div>
  </footer>
</Layout>

<style>
  .main {
    padding-top: 80px;
    min-height: 100vh;
  }

  .section {
    padding: var(--spacing-2xl) 0;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 var(--spacing-lg);
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--spacing-2xl);
  }

  .page-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 600;
    margin-bottom: var(--spacing-md);
  }

  .page-description {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--spacing-lg);
  }

  .gallery-item {
    position: relative;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-lg);
    overflow: hidden;
    cursor: pointer;
    background: var(--color-surface);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .gallery-item:hover img {
    transform: scale(1.05);
  }

  .gallery-item-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.9) 0%, transparent 60%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--spacing-lg);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .gallery-item:hover .gallery-item-overlay {
    opacity: 1;
  }

  .gallery-item-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: var(--spacing-sm);
  }

  .gallery-item-link {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    color: var(--color-primary);
    font-size: 0.875rem;
    font-weight: 500;
    transition: gap var(--transition-fast);
  }

  .gallery-item-link:hover {
    gap: var(--spacing-sm);
  }

  .footer {
    padding: var(--spacing-xl) 0;
    border-top: 1px solid var(--color-border);
    text-align: center;
    color: var(--color-text-secondary);
  }

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Gallery item click handlers
  document.addEventListener('DOMContentLoaded', () => {
    const galleryItems = document.querySelectorAll('.gallery-item');
    
    // Collect all images for gallery view
    const images = Array.from(galleryItems).map(item => ({
      url: item.getAttribute('data-image-url') || '',
      title: item.getAttribute('data-image-title') || ''
    }));

    galleryItems.forEach((item, index) => {
      item.addEventListener('click', (e) => {
        // Don't open gallery if clicking on the project link
        if ((e.target as HTMLElement).closest('.gallery-item-link')) {
          return;
        }
        
        (window as any).openGallery(images, index);
      });
    });
  });
</script>
