---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ProjectCard from '../components/ProjectCard.astro';
import GalleryView from '../components/GalleryView.astro';
import { projects, getBestPictures } from '../data/projects';

const bestPictures = getBestPictures();
const featuredProjects = projects.slice(0, 6);
---

<Layout title="egyheppem - Kosiba Zsófia Photography">
  <Header />
  <GalleryView />
  
  <main class="main">
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-content animate-fade-in">
        <h1 class="hero-title">egyheppem</h1>
        <p class="hero-subtitle">Kosiba Zsófia</p>
        <p class="hero-tagline">Capturing moments that tell stories beyond words</p>
      </div>
      <div class="hero-scroll">
        <span>Scroll to explore</span>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </div>
    </section>

    <!-- Best Pictures Section -->
    <section class="section bests-section">
      <div class="container">
        <div class="section-header animate-fade-in">
          <h2 class="section-title">Best Pictures</h2>
          <a href="/best-pictures" class="section-link">
            View all
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>

        <div class="slideshow animate-scale-in stagger-1">
          {bestPictures.slice(0, 5).map((picture, index) => (
            <div class="slide" data-index={index}>
              <img src={picture.url || "/placeholder.svg"} alt={picture.title} />
              <div class="slide-info">
                <h3>{picture.title}</h3>
                <p>{picture.projectTitle}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Services Section -->
    <section class="section services-section">
      <div class="container">
        <h2 class="section-title animate-fade-in">Services</h2>
        
        <div class="services-grid">
          <div class="service-item animate-fade-in stagger-1">
            <button class="service-header">
              <h3 class="service-title">Wedding Photography</h3>
              <svg class="service-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </button>
            <div class="service-content">
              <p class="service-description">Documenting your special day with elegance and emotion, capturing every precious moment.</p>
              <div class="service-examples">
                <a href="/projects/wedding-moments" class="example-card">
                  <img src="/placeholder.svg?height=200&width=300" alt="Wedding example" />
                  <div class="example-info">
                    <span class="example-title">Wedding Moments</span>
                    <span class="example-count">45 images</span>
                  </div>
                </a>
              </div>
            </div>
          </div>

          <div class="service-item animate-fade-in stagger-2">
            <button class="service-header">
              <h3 class="service-title">Portrait Sessions</h3>
              <svg class="service-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </button>
            <div class="service-content">
              <p class="service-description">Intimate portraits that reveal the unique character and personality of each subject.</p>
              <div class="service-examples">
                <a href="/projects/portrait-sessions" class="example-card">
                  <img src="/placeholder.svg?height=200&width=300" alt="Portrait example" />
                  <div class="example-info">
                    <span class="example-title">Portrait Sessions</span>
                    <span class="example-count">32 images</span>
                  </div>
                </a>
              </div>
            </div>
          </div>

          <div class="service-item animate-fade-in stagger-3">
            <button class="service-header">
              <h3 class="service-title">Commercial Work</h3>
              <svg class="service-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </button>
            <div class="service-content">
              <p class="service-description">Professional photography for brands and businesses, elevating your visual identity.</p>
              <div class="service-examples">
                <a href="/projects/commercial-work" class="example-card">
                  <img src="/placeholder.svg?height=200&width=300" alt="Commercial example" />
                  <div class="example-info">
                    <span class="example-title">Commercial Work</span>
                    <span class="example-count">28 images</span>
                  </div>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Projects Section -->
    <section class="section projects-section">
      <div class="container">
        <div class="section-header animate-fade-in">
          <h2 class="section-title">Featured Projects</h2>
          <a href="/projects" class="btn-primary">
            Welcome to my project gallery
          </a>
        </div>

        <div class="projects-grid">
          {featuredProjects.map((project, index) => (
            <div class={`animate-scale-in stagger-${index + 1}`}>
              <ProjectCard {...project} />
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container">
      <p>&copy; 2025 Kosiba Zsófia. All rights reserved.</p>
    </div>
  </footer>
</Layout>

<style>
  .main {
    padding-top: 80px;
  }

  .hero {
    min-height: 90vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--spacing-2xl) var(--spacing-lg);
    position: relative;
  }

  .hero-content {
    max-width: 800px;
  }

  .hero-title {
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 600;
    margin-bottom: var(--spacing-md);
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-lg);
  }

  .hero-tagline {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .hero-scroll {
    position: absolute;
    bottom: var(--spacing-2xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-xs);
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    animation: bounce 2s infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .section {
    padding: var(--spacing-2xl) 0;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 var(--spacing-lg);
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--spacing-xl);
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
  }

  .section-link {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    color: var(--color-primary);
    font-weight: 500;
    transition: gap var(--transition-fast);
  }

  .section-link:hover {
    gap: var(--spacing-sm);
  }

  .slideshow {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--color-surface);
  }

  .slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity var(--transition-slow);
  }

  .slide.active {
    opacity: 1;
  }

  .slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .slide-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--spacing-xl);
    background: linear-gradient(to top, rgba(0, 0, 0, 0.9) 0%, transparent 100%);
  }

  .slide-info h3 {
    font-size: 1.5rem;
    margin-bottom: var(--spacing-xs);
  }

  .slide-info p {
    color: var(--color-text-secondary);
  }

  .services-grid {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .service-item {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .service-header {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-lg);
    cursor: pointer;
    transition: background var(--transition-fast);
  }

  .service-header:hover {
    background: var(--color-surface-hover);
  }

  .service-title {
    font-size: 1.5rem;
    font-weight: 600;
    text-align: left;
  }

  .service-icon {
    transition: transform var(--transition-base);
  }

  .service-item.active .service-icon {
    transform: rotate(180deg);
  }

  .service-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height var(--transition-slow);
  }

  .service-item.active .service-content {
    max-height: 500px;
  }

  .service-description {
    padding: 0 var(--spacing-lg);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .service-examples {
    padding: var(--spacing-lg);
  }

  .example-card {
    display: block;
    background: var(--color-surface-elevated);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: transform var(--transition-base);
  }

  .example-card:hover {
    transform: translateY(-2px);
  }

  .example-card img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
  }

  .example-info {
    padding: var(--spacing-md);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .example-title {
    font-weight: 500;
  }

  .example-count {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: var(--spacing-lg);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: var(--spacing-md) var(--spacing-lg);
    background: var(--color-primary);
    color: var(--color-background);
    font-weight: 600;
    border-radius: var(--radius-md);
    transition: background var(--transition-fast), transform var(--transition-fast);
  }

  .btn-primary:hover {
    background: var(--color-primary-hover);
    transform: translateY(-2px);
  }

  .footer {
    padding: var(--spacing-xl) 0;
    border-top: 1px solid var(--color-border);
    text-align: center;
    color: var(--color-text-secondary);
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }

    .section-header {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--spacing-md);
    }
  }
</style>

<script>
  // Slideshow functionality
  let currentSlide = 0;
  const slides = document.querySelectorAll('.slide');
  
  function showSlide(index: number) {
    slides.forEach((slide, i) => {
      slide.classList.toggle('active', i === index);
    });
  }

  function nextSlide() {
    currentSlide = (currentSlide + 1) % slides.length;
    showSlide(currentSlide);
  }

  // Initialize slideshow
  if (slides.length > 0) {
    showSlide(0);
    setInterval(nextSlide, 4000);
  }

  // Accordion functionality
  document.querySelectorAll('.service-header').forEach(header => {
    header.addEventListener('click', () => {
      const item = header.closest('.service-item');
      const wasActive = item?.classList.contains('active');
      
      // Close all accordions
      document.querySelectorAll('.service-item').forEach(i => i.classList.remove('active'));
      
      // Open clicked accordion if it wasn't active
      if (!wasActive) {
        item?.classList.add('active');
      }
    });
  });
</script>
